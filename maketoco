-- ================== HÀM HỖ TRỢ ==================
local function ForceClick(button)
    if not button then return end
    if getconnections then
        for _, connection in pairs(getconnections(button.MouseButton1Click)) do connection:Fire() end
        for _, connection in pairs(getconnections(button.Activated)) do connection:Fire() end
    else
        local vim = game:GetService("VirtualInputManager")
        local pos = button.AbsolutePosition
        local size = button.AbsoluteSize
        vim:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 36, 0, true, game, 1)
        task.wait(0.05)
        vim:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2 + 36, 0, false, game, 1)
    end
end

local function HandleSellUI(mode)
    for _, gui in pairs(Player.PlayerGui:GetDescendants()) do
        if mode == "Sell" then
            if (gui:IsA("TextLabel") or gui:IsA("TextButton")) then
                local textLower = gui.Text:lower()
                if textLower:match("sell all") or textLower:match("bán hết") then
                    local btn = gui:IsA("TextButton") and gui or gui:FindFirstAncestorWhichIsA("TextButton") or gui:FindFirstAncestorWhichIsA("ImageButton")
                    if btn and btn.Visible then ForceClick(btn) return true end
                end
            end
        elseif mode == "Close" then
            if (gui:IsA("ImageButton") or gui:IsA("TextButton")) then
                local nameLower = gui.Name:lower()
                local isX = (gui:IsA("TextButton") and gui.Text == "X") or nameLower:match("close") or nameLower:match("exit") or nameLower:match("x$")
                if isX and gui.Visible then ForceClick(gui) return true end
            end
        end
    end
    return false
end

local function IsBagFull()
    for _, v in pairs(Player.PlayerGui:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") then
            local txt = v.Text:lower()
            if (txt:match("full") or txt:match("đầy") or txt:match("100%%")) and v.Visible and v.TextBounds.X > 0 then
                return true
            end
        end
    end
    local stats = Player:FindFirstChild("leaderstats")
    if stats then
        local storage = stats:FindFirstChild("Storage") or stats:FindFirstChild("Fish") or stats:FindFirstChild("Backpack")
        local maxStorage = stats:FindFirstChild("MaxStorage") or stats:FindFirstChild("Max")
        if storage and maxStorage and tonumber(storage.Value) and tonumber(maxStorage.Value) then
            if tonumber(storage.Value) >= tonumber(maxStorage.Value) then return true end
        end
    end
    return false
end

-- ================== TWEEN TỐC ĐỘ 50 (ĐÃ LỌC TỪ SCRIPT BẠN ĐƯA) ==================
local function TweenToCFrame(targetCFrame)
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local Root = Character:WaitForChild("HumanoidRootPart", 5)
    if not Root then return end

    -- HỦY TWEEN ĐANG CHẠY (để đổi đảo ngay lập tức)
    if currentTween then
        currentTween:Cancel()
    end

    local Distance = (targetCFrame.Position - Root.Position).Magnitude
    local Duration = Distance / 120

    currentTween = TweenService:Create(
        Root,
        TweenInfo.new(Duration, Enum.EasingStyle.Linear),
        {CFrame = targetCFrame}
    )

    currentTween:Play()

    currentTween.Completed:Connect(function()
        currentTween = nil
    end)
end

-- ================== ACTION SELL ==================
local function ActionSell()
    local Character = Player.Character
    local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end

    local targetNPC = nil
    local dist = math.huge
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v.Name == SellNPCName and v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") then
            local m = (RootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if m < dist then dist = m targetNPC = v end
        end
    end

    if targetNPC then
        local oldPos = RootPart.CFrame
        print(L.msgSelling)

        TweenToCFrame(targetNPC.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3))
        task.wait(0.5)

        local prompt = targetNPC:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then fireproximityprompt(prompt) end
        
        task.wait(0.8)
        for i = 1, 3 do if HandleSellUI("Sell") then break end task.wait(0.3) end
        task.wait(0.8)
        for i = 1, 3 do if HandleSellUI("Close") then break end task.wait(0.2) end
        
        TweenToCFrame(oldPos)
        task.wait(0.5)
        print(L.msgDone)
    end
end

