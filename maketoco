-- ================== AUTO LOOP ==================
task.spawn(function()
    local lastSell = 0
    while true do
        task.wait(1)
        if autoActive then
            if sellWhenFull then
                if IsBagFull() then ActionSell() task.wait(5) end
            else
                if tick() - lastSell >= sellDelay then
                    ActionSell()
                    lastSell = tick()
                end
            end
        end
    end
end)
